# backcast — per-machine config. Copy to `.env` (gitignored) and set for THIS machine.
# External-storage paths and dev credentials differ per 端末, so they are read from here /
# process env, never hardcoded. EnvConfig (C#) and engine.paths (Python) read these.
# Everything below is OPTIONAL: unset keys fall back to a default or make the dependent
# feature skip-if-absent. Uncomment + set only what you need.

# ===========================================================================
# Market data — Replay source
# ===========================================================================

# Going-forward Replay source (ADR-0006): owner's J-Quants DuckDB market-data root.
# Per-symbol files at <root>/stocks_daily/<code>.duckdb, <root>/stocks_minute/<code>.duckdb,
# plus listed_info.duckdb (master). Read by engine.paths.jquants_duckdb_root() (#47/#48
# DuckDB direct-read). Unset → real-data readers/tests skip-if-absent (no bogus default).
# BACKCAST_JQUANTS_DUCKDB_ROOT=/Volumes/StockData/jp

# LEGACY nautilus parquet catalog root (catalog lives at <ARTIFACTS_PATH>/jquants-catalog).
# Read by engine.paths.jquants_catalog_path() and the #29 Scenario Startup HITL harness.
# Being retired with nautilus in #50 — prefer BACKCAST_JQUANTS_DUCKDB_ROOT above. Defaults
# to repo-relative "artifacts" when unset.
# ARTIFACTS_PATH=/Volumes/StockData/artifacts

# ===========================================================================
# #29 Scenario Startup HITL overrides (optional)
# ===========================================================================

# Full path to the LEGACY parquet catalog (wins over ARTIFACTS_PATH/jquants-catalog) if it
# lives elsewhere. Retiring with nautilus (#50).
# BACKCAST_CATALOG_PATH=/Volumes/StockData/artifacts/jquants-catalog

# Strategy .py the Startup tile configures. Defaults to the kernel-native repo fixture
# kernel_spike_buy_sell.py (ADR-0006 #49: production Replay runs the nautilus-free kernel, so
# the strategy must subclass engine.kernel.strategy.Strategy — a nautilus Strategy would fail
# the loader). Set this to your own kernel-native strategy .py to override.
# BACKCAST_HITL_STRATEGY=/abs/path/to/your_kernel_strategy.py

# ===========================================================================
# Live venue dev credentials (demo by default)
# ===========================================================================
# SECURITY: the 第二暗証番号 (second secret) is NEVER read from env — it is collected
# in-call and not persisted to env/log. Do NOT add a second-secret key here.

# 立花 e支店 (tachibana). DEV_TACHIBANA_DEMO defaults to "true" (demo env) when unset.
# DEV_TACHIBANA_USER_ID=
# DEV_TACHIBANA_PASSWORD=
# DEV_TACHIBANA_DEMO=true

# auカブコム / kabu (kabusapi) — API password for kabuステーション.
# DEV_KABU_API_PASSWORD=

# Live demo HITL venue selection (#23). The live venue is one-per-server and bound when the
# BackcastWorkspaceRoot builds the server at Play start, so it must be chosen via env BEFORE Play
# (default MOCK keeps the Replay mainline credential-less). Set to TACHIBANA or KABU for a real-venue
# demo roundtrip, optionally pin the manual-ticket instrument with LIVE_INSTRUMENT.
# LIVE_VENUE=TACHIBANA
# LIVE_INSTRUMENT=8918.TSE

# ===========================================================================
# Misc / dev (optional overrides — sensible defaults when unset)
# ===========================================================================

# J-Quants API response cache dir (data fetching).
# DEV_J_QUANTS_CACHE=/abs/path/to/jquants-cache

# Override the instruments store dir (default: <LOCALAPPDATA>/the-trader-was-replaced/instruments).
# INSTRUMENTS_CACHE_DIR=/abs/path/to/instruments

# Override the tachibana session cache path.
# TACHIBANA_SESSION_PATH=/abs/path/to/tachibana-session.json

# Live login subprocess timeout in seconds (default 180).
# LIVE_LOGIN_TIMEOUT_S=180

# Strategy-param universe JSON path (strategy_replay CLI).
# STRATEGY_PARAM_UNIVERSE_JSON_PATH=/abs/path/to/universe.json

# Python interpreter for the embedded login subprocess (set by run_inproc.ps1 on Windows).
# TTWR_PYTHON_BIN=/abs/path/to/python
