# backcast — per-machine config. Copy to `.env` (gitignored) and set for THIS machine.
# External-storage paths differ per端末, so they are read from here / process env, never
# hardcoded. EnvConfig (C#) and engine.paths (Python) read these.

# Root of the artifacts tree (J-Quants parquet catalog lives at <ARTIFACTS_PATH>/jquants-catalog).
# Used by engine.paths.jquants_catalog_path() and the #29 Scenario Startup HITL harness.
ARTIFACTS_PATH=S:\artifacts

# --- optional #29 HITL overrides ---
# Full catalog path (wins over ARTIFACTS_PATH/jquants-catalog) if your catalog is elsewhere:
# BACKCAST_CATALOG_PATH=S:\artifacts\jquants-catalog
# Strategy .py the Startup tile configures (defaults to the repo spike_buy_sell.py fixture):
# BACKCAST_HITL_STRATEGY=C:\path\to\your_strategy.py
